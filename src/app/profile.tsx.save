import { View, Text, Image, ScrollView } from "react-native";
import { useVideos } from "../context/VideoContext";

export default function Profile() {
  const { videos } = useVideos();

  return (
    <ScrollView
      style={{ flex: 1, backgroundColor: "#000" }}
      contentContainerStyle={{
        alignItems: "center",
        paddingTop: 60,
      }}
    >
      <Image
        source={{ uri: "https://i.pravatar.cc/200" }}
        style={{
          width: 100,
          height: 100,
          borderRadius: 50,
        }}
      />

      <Text
        style={{
          color: "#fff",
          fontSize: 22,
          fontWeight: "bold",
          marginTop: 15,
        }}
      >
        @clipx_user
      </Text>

      <Text style={{ color: "#aaa", marginTop: 10 }}>
        Uploaded Videos: {videos.length}
      </Text>

      {videos.length === 0 ? (
        <Text
          style={{
            color: "#fff",
            marginTop: 40,
            fontSize: 18,
          }}
        >
          No Videos Yet
        </Text>
      ) : (
        <View
          style={{
            width: "100%",
            padding: 20,
          }}
        >
          <View
            style={{
              flexDirection: "row",
              flexWrap: "wrap",
              justifyContent: "space-between",
            }}
          >
            {videos.map((video, index) => (
              <View
                key={index}
                style={{
                  width: "32%",
                  height: 160,
                  backgroundColor: "#222",
                  marginBottom: 4,
                  justifyContent: "center",
                  alignItems: "center",
                }}
              >
                <Text style={{ color: "#fff", textAlign: "center" }}>
                  🎥 Video {index + 1}
                </Text>
              </View>
            ))}
          </View>
        </View>
      )}
    </ScrollView>
  );
}
